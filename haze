            if plr.Character then
                local arm = plr.Character:FindFirstChild("Right Arm") or plr.Character:FindFirstChild("RightHand")
                if arm and data then
                    arm.Size = data.Size
                    arm.Transparency = data.Transparency
                end
            end
        end
        originalSizes = {}
    end
end)

createButton(hitboxPage, "+", 40).MouseButton1Click:Connect(function() hitboxSize = hitboxSize + 1 end)
createButton(hitboxPage, "-", 70).MouseButton1Click:Connect(function() hitboxSize = math.max(1, hitboxSize - 1) end)

RunService.RenderStepped:Connect(function()
    if not hitboxEnabled then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local arm = plr.Character:FindFirstChild("Right Arm") or plr.Character:FindFirstChild("RightHand")
            if arm then
                if not originalSizes[plr] then
                    originalSizes[plr] = {Size = arm.Size, Transparency = arm.Transparency}
                end
                arm.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                arm.Transparency = 0.3
            end
        end
    end
end)

-- Função para verificar parede
local function hasWall(origin, targetPos, targetChar)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, targetChar}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    return workspace:Raycast(origin, targetPos - origin, params) ~= nil
end

-- Pega o alvo mais próximo dentro do FOV
local function getTarget()
    local bestDist = math.huge
    local bestTarget = nil
    local center = Camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local headPos, visible = Camera:WorldToViewportPoint(plr.Character.Head.Position)
                if visible then
                    local dist = (Vector2.new(headPos.X, headPos.Y) - center).Magnitude
                    if dist <= FOV then
                        if not wallCheck or not hasWall(Camera.CFrame.Position, plr.Character.Head.Position, plr.Character) then
                            if dist < bestDist then
                                bestDist = dist
                                bestTarget = plr.Character
                            end
                        end
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Silent Aim (redireciona o tiro quando você atira)
WeaponFired.OnClientEvent:Connect(function()
    if not aimbot then return end

    local targetChar = getTarget()
    if not targetChar or not targetChar:FindFirstChild("Head") then return end

    local head = targetChar.Head
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")

    if tool then
        WeaponHit:FireServer(tool, {
            p = head.Position,
            pid = 1,
            part = head,
            d = (head.Position - Camera.CFrame.Position).Magnitude,
            maxDist = 100,
            h = head,
            m = Enum.Material.Plastic,
            n = Vector3.new(0,1,0),
            t = 0.5,
            s = head.Size,
            sid = 1
        }, true)
    end
end)

