-- ======= Arm utilities (ORIGINAL) =======
local R6 = {"Right Arm","Left Arm"}
local R15 = {"RightUpperArm","RightLowerArm","RightHand","LeftUpperArm","LeftLowerArm","LeftHand"}

local function forEachArm(char, fn)
    for _,n in ipairs(R6) do
        local p = char:FindFirstChild(n)
        if p and p:IsA("BasePart") then fn(p, n) end
    end
    for _,n in ipairs(R15) do
        local p = char:FindFirstChild(n)
        if p and p:IsA("BasePart") then fn(p, n) end
    end
end

local function setArmWidth(char, width)
    forEachArm(char, function(part)
        if not part or not part:IsA("BasePart") then return end
        part.CanCollide = false
        part.Massless = true
        part.Size = Vector3.new(width, part.Size.Y, width)
    end)
end

local function clearFakes(char)
    for _,n in ipairs(R6) do local f = char:FindFirstChild(n.."_Fake"); if f then f:Destroy() end end
    for _,n in ipairs(R15) do local f = char:FindFirstChild(n.."_Fake"); if f then f:Destroy() end end
end

local function applyInvisibleToChar(char, state)
    forEachArm(char, function(arm, name)
        if not arm then return end
        local fakeName = name .. "_Fake"
        if state then
            arm.Transparency = 1
            if not char:FindFirstChild(fakeName) then
                local fake = Instance.new("Part")
                fake.Name = fakeName
                fake.Size = Vector3.new(1, arm.Size.Y, 1)
                fake.Color = arm.Color
                fake.Material = arm.Material
                fake.CanCollide = false
                fake.Massless = true
                fake.Parent = char
                fake.CFrame = arm.CFrame
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = fake
                weld.Part1 = arm
                weld.Parent = fake
            end
        else
            arm.Transparency = 0
            local fake = char:FindFirstChild(fakeName)
            if fake then fake:Destroy() end
        end
    end)
end

local function resetToNormal(char)
    if not char then return end
    clearFakes(char)
    forEachArm(char, function(arm)
        if not arm then return end
        arm.Transparency = 0
        arm.CanCollide = false
        arm.Massless = true
        arm.Size = Vector3.new(1, arm.Size.Y, 1)
    end)
end

local function shouldAffect(plr)
    return plr ~= LP and not excluded[plr.Name]
end

local function applyToCharacter(char, owner)
    if not char or not owner then return end
    if not shouldAffect(owner) then
        resetToNormal(char)
        return
    end
    setArmWidth(char, ArmWidth)
    applyInvisibleToChar(char, Invisible)
end

local function applyToAll()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            applyToCharacter(plr.Character, plr)
        end
    end
end

local function waitForAnyArm(char, timeout)
    timeout = timeout or 5
    local t0 = tick()
    while tick() - t0 < timeout do
        for _,n in ipairs(R6) do if char:FindFirstChild(n) then return true end end
        for _,n in ipairs(R15) do if char:FindFirstChild(n) then return true end end
        task.wait(0.08)
    end
    return false
end

local function onCharacterAdded(plr, char)
    if not plr or not char then return end
    waitForAnyArm(char, 6)
    if excluded[plr.Name] then
        resetToNormal(char)
    else
        setArmWidth(char, ArmWidth)
        applyInvisibleToChar(char, Invisible)
    end

    local conn
    conn = char.DescendantAdded:Connect(function(desc)
        if not desc or not desc:IsA("BasePart") then return end
        local name = desc.Name
        for _,n in ipairs(R6) do
            if name == n then
                task.wait(0.08)
                if excluded[plr.Name] then resetToNormal(char) else setArmWidth(char, ArmWidth); applyInvisibleToChar(char, Invisible) end
                return
            end
        end
        for _,n in ipairs(R15) do
            if name == n then
                task.wait(0.08)
                if excluded[plr.Name] then resetToNormal(char) else setArmWidth(char, ArmWidth); applyInvisibleToChar(char, Invisible) end
                return
            end
        end
    end)

    char.AncestryChanged:Connect(function(_, parent)
        if not parent and conn then conn:Disconnect() end
    end)
end

local function hookPlayer(plr)
    if plr == LP then return end
    plr.CharacterAdded:Connect(function(char)
        task.wait(0.2)
        onCharacterAdded(plr, char)
    end)
    if plr.Character then
        task.defer(function() onCharacterAdded(plr, plr.Character) end)
    end
end

for _,p in ipairs(Players:GetPlayers()) do hookPlayer(p) end
Players.PlayerAdded:Connect(function(p)
    hookPlayer(p)
    if ExList.Visible then
        ExBtn.MouseButton1Click:Fire()
        ExBtn.MouseButton1Click:Fire()
    end
end)
Players.PlayerRemoving:Connect(function(p) excluded[p.Name] = nil end)

-- ======= Slider behavior (ORIGINAL + FIX) =======
local dragging = false
local dragInput = nil

local function ratioFromInput(input)
    local x = input.Position.X
    local r = (x - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X
    return math.clamp(r, 0, 1)
end

local function setKnobFromRatio(r)
    r = math.clamp(r, 0, 1)
    local y = SliderBar.AbsolutePosition.Y - panel.AbsolutePosition.Y + (SliderBar.AbsoluteSize.Y/2) - (Knob.AbsoluteSize.Y/2)
    local x = SliderBar.AbsolutePosition.X - panel.AbsolutePosition.X + r * SliderBar.AbsoluteSize.X - (Knob.AbsoluteSize.X/2)
    Knob.Position = UDim2.new(0, x, 0, y)
    ArmWidth = math.floor(MIN_SIZE + r*(MAX_SIZE - MIN_SIZE))
    ValueLabel.Text = tostring(ArmWidth)
    applyToAll()
end

local function beginDrag(input)
    dragging = true
    dragInput = input
    panel.Draggable = false
    setKnobFromRatio(ratioFromInput(input))
    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then
            dragging = false
            dragInput = nil
            task.wait()
            panel.Draggable = true
        end
    end)
end

Knob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        beginDrag(input)
    end
end)

SliderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        beginDrag(input)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        setKnobFromRatio(ratioFromInput(input))
    end
end)

task.defer(function()
    setKnobFromRatio((ArmWidth - MIN_SIZE)/(MAX_SIZE - MIN_SIZE))
end)

