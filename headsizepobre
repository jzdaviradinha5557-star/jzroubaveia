local function rebuildExList()
    ExList:ClearAllChildren()
    local layout = Instance.new("UIListLayout", ExList)
    layout.Padding = UDim.new(0,4)
    layout.FillDirection = Enum.FillDirection.Vertical

    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            local row = Instance.new("TextButton")
            row.Parent = ExList
            row.Size = UDim2.new(1,0,0,24)
            row.BackgroundColor3 = Color3.fromRGB(40,40,40)
            row.TextColor3 = Color3.fromRGB(255,255,255)
            row.Font = Enum.Font.Gotham
            row.TextSize = 14
            row.TextXAlignment = Enum.TextXAlignment.Left
            row.AutoButtonColor = true

            local checked = excluded[plr.Name] == true
            row.Text = (checked and "✔  " or "") .. plr.Name

            row.MouseButton1Click:Connect(function()
                if excluded[plr.Name] then
                    excluded[plr.Name] = nil
                    row.Text = plr.Name
                    if plr.Character then applyToCharacter(plr.Character, plr) end
                else
                    excluded[plr.Name] = true
                    row.Text = "✔  " .. plr.Name
                    if plr.Character then resetToNormal(plr.Character) end
                end
            end)
        end
    end
end

ExBtn.MouseButton1Click:Connect(function()
    ExList.Visible = not ExList.Visible
    if ExList.Visible then rebuildExList() end
end)

